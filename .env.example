# ============================================
# Hache Code - Variables de Entorno
# ============================================
# Copia este archivo como .env.local y completa los valores:
#   cp .env.example .env.local
#
# En Vercel/Railway: Configura estas variables en el dashboard
# de tu plataforma de deploy.
# ============================================

# ─────────────────────────────────────────────
# REQUERIDAS (sin estas la app NO funciona)
# ─────────────────────────────────────────────

# URL base de tu API compatible con OpenAI
# Debe apuntar al endpoint de chat completions (sin /chat/completions)
# Ejemplos:
#   OpenAI:        https://api.openai.com/v1
#   ChatGLM:       https://open.bigmodel.cn/api/paas/v4
#   Groq:          https://api.groq.com/openai/v1
#   Together:      https://api.together.xyz/v1
#   Local (Ollama): http://localhost:11434/v1
API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Tu API key del proveedor
API_KEY=tu-api-key-aqui

# ─────────────────────────────────────────────
# OPCIONALES
# ─────────────────────────────────────────────

# Modelo a usar (default: glm-4-plus para ChatGLM)
# Otros ejemplos: gpt-4o, gpt-4o-mini, llama-3.1-70b, etc.
API_MODEL=glm-4-plus

# Deshabilitar streaming (default: true)
# Cambia a "false" si tu API no soporta streaming
API_STREAM=true
