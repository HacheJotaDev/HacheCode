# ============================================
# Hache Code - Variables de Entorno
# ============================================
# Copia este archivo como .env.local y completa los valores
# cp .env.example .env.local
#
# HAY 2 FORMAS de configurar la API para Vercel:
#   Opción A: Proxy (más fácil) — Solo necesitas ZAI_PROXY_URL
#   Opción B: Gateway directo — Necesitas ZAI_BASE_URL + ZAI_API_KEY + token
# ============================================

# ─────────────────────────────────────────────
# OPCIÓN A: Proxy (RECOMENDADO para Vercel)
# ─────────────────────────────────────────────
# URL de una instancia de Z.ai que funciona como proxy
# La app llamará a este endpoint que internamente usa el SDK
ZAI_PROXY_URL=https://codes.space-z.ai/api/chat

# ─────────────────────────────────────────────
# OPCIÓN B: Gateway directo
# ─────────────────────────────────────────────
# URL base del gateway de Z.ai (solo si tienes acceso directo)
# ZAI_BASE_URL=http://172.25.136.193:8080/v1

# API Key para autenticación
# ZAI_API_KEY=Z.ai

# Token JWT (requerido para autenticación en el gateway)
# ZAI_TOKEN=tu-token-jwt

# ID de chat persistente (opcional)
# ZAI_CHAT_ID=chat-xxx

# ID de usuario (opcional)
# ZAI_USER_ID=xxx
