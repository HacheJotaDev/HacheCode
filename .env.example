# ============================================
# Hache Code - Variables de Entorno
# ============================================
# Copia este archivo como .env.local y completa los valores:
#   cp .env.example .env.local
#
# En Vercel/Railway: Configura estas variables en el dashboard
# de tu plataforma de deploy.
#
# La app detecta automáticamente qué API usar:
#   1. Claude models → Anthropic API (si ANTHROPIC_API_KEY está configurada)
#   2. Otros modelos → OpenAI-compatible API (si API_BASE_URL + API_KEY)
#   3. Fallback → Z.ai SDK automático (en codespace Z.ai)
# ============================================

# ─────────────────────────────────────────────
# OPCIÓN A: Anthropic Claude API
# ─────────────────────────────────────────────
# Obtén tu API key en: https://console.anthropic.com/
# Necesaria para usar modelos Claude (claude-sonnet-4, claude-3.5-sonnet, etc.)
ANTHROPIC_API_KEY=tu-anthropic-api-key-aqui

# ─────────────────────────────────────────────
# OPCIÓN B: API compatible con OpenAI
# ─────────────────────────────────────────────
# URL base de tu API (sin /chat/completions)
# Ejemplos:
#   ChatGLM:       https://open.bigmodel.cn/api/paas/v4
#   Groq:          https://api.groq.com/openai/v1
#   OpenAI:        https://api.openai.com/v1
#   OpenRouter:    https://openrouter.ai/api/v1
API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Tu API key del proveedor
API_KEY=tu-api-key-aqui

# ─────────────────────────────────────────────
# OPCIONALES
# ─────────────────────────────────────────────
# Modelo por defecto (si no se selecciona uno en la UI)
# Ejemplos: claude-sonnet-4-20250514, glm-4-plus, gpt-4o
API_MODEL=glm-4-plus

# Deshabilitar streaming (default: true)
API_STREAM=true
