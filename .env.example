# ═══════════════════════════════════════════════════════════════
# Hache IA - Variables de Entorno
# ═══════════════════════════════════════════════════════════════
# La app detecta automaticamente que API usar (en orden de prioridad):
#   1. ANTHROPIC_API_KEY + modelo claude-* → Anthropic Claude API
#   2. API_BASE_URL + API_KEY → OpenAI-compatible API (/chat/completions)
#   3. ZAI_PROXY_URL → Proxy via sandbox Z.ai (/api/chat)
#   4. Z.ai SDK automatico (solo dentro de Z.ai codespace)
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# OPCION 1: Cloudflare Tunnel + Proxy (RECOMENDADO)
# ─────────────────────────────────────────────
# El proxy en el sandbox se expone via Cloudflare Named Tunnel.
# API_BASE_URL apunta al dominio fijo del tunnel.
# No necesitas API key - el proxy maneja la autenticacion internamente.
API_BASE_URL=https://api.hacheia.xyz
API_KEY=hache-ia-proxy
API_MODEL=glm-4-plus

# ─────────────────────────────────────────────
# OPCION 2: Anthropic Claude API
# ─────────────────────────────────────────────
# Obten tu API key en: https://console.anthropic.com/
# Solo necesitas esta variable para usar modelos Claude.
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─────────────────────────────────────────────
# OPCION 3: API compatible con OpenAI
# ─────────────────────────────────────────────
# Funciona con OpenAI, Groq, OpenRouter, ChatGLM, etc.
# API_BASE_URL=https://api.openai.com/v1
# API_KEY=sk-xxxxx
# API_MODEL=gpt-4

# ─────────────────────────────────────────────
# OPCION 4: Z.ai Proxy Legacy
# ─────────────────────────────────────────────
# Solo si usas un tunnel temporal (trycloudflare.com)
# ZAI_PROXY_URL=https://xxx.trycloudflare.com

# ─────────────────────────────────────────────
# Configuracion del Proxy Server (sandbox)
# ─────────────────────────────────────────────
# PROXY_PORT=3000
# BLOCK_DIRECT_ACCESS=true

# ─────────────────────────────────────────────
# NOTA
# ─────────────────────────────────────────────
# Si NO configuras ninguna variable, la app usara el SDK de Z.ai
# automaticamente cuando se ejecute dentro de un codespace de Z.ai.
