# ============================================
# Hache Code - Variables de Entorno
# ============================================
# En Vercel/Railway: Configura estas variables en el dashboard.
#
# La app detecta automáticamente qué API usar (en orden):
#   1. claude-* + ANTHROPIC_API_KEY → Anthropic Claude API
#   2. API_BASE_URL + API_KEY → OpenAI-compatible API
#   3. ZAI_PROXY_URL → Proxy vía codespace Z.ai
#   4. Z.ai SDK automático (solo dentro de Z.ai)
# ============================================

# ─────────────────────────────────────────────
# OPCIÓN A: Anthropic Claude API (recomendado)
# ─────────────────────────────────────────────
# Obtén tu API key en: https://console.anthropic.com/
# Solo necesitas esta variable para usar modelos Claude
ANTHROPIC_API_KEY=tu-anthropic-api-key-aqui

# ─────────────────────────────────────────────
# OPCIÓN B: API compatible con OpenAI
# ─────────────────────────────────────────────
# Ejemplos:
#   ChatGLM:       https://open.bigmodel.cn/api/paas/v4
#   Groq:          https://api.groq.com/openai/v1
#   OpenAI:        https://api.openai.com/v1
API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
API_KEY=tu-api-key-aqui

# ─────────────────────────────────────────────
# OPCIÓN C: Proxy Z.ai (para Vercel sin API key)
# ─────────────────────────────────────────────
# URL de tu codespace Z.ai activo
# El codespace debe estar corriendo para que funcione
# Ejemplo: https://codes.space-z.ai
ZAI_PROXY_URL=https://codes.space-z.ai

# ─────────────────────────────────────────────
# OPCIONALES
# ─────────────────────────────────────────────
# Modelo por defecto
API_MODEL=glm-4-plus
API_STREAM=true
