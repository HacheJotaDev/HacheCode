# ============================================
# Hache Code - Variables de Entorno
# ============================================
# Copia este archivo como .env.local y completa los valores
# cp .env.example .env.local
#
# Estas variables SON NECESARIAS para despliegue en Vercel.
# En el entorno local de Z.ai, el SDK se configura automáticamente.
# ============================================

# URL base de la API de IA (requerido para Vercel)
# Debe incluir el path /v1 al final
ZAI_BASE_URL=https://your-api-url/v1

# Clave de API para autenticación (requerido para Vercel)
ZAI_API_KEY=your-api-key

# ID de chat persistente (opcional)
ZAI_CHAT_ID=

# ID de usuario (opcional)
ZAI_USER_ID=

# Token adicional (opcional)
ZAI_TOKEN=
